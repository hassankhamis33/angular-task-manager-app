# Angular Task Manager - Development Environment Configuration
# Copy this file to .env.local for local environment variables

# Node Environment
NODE_ENV=development

# Angular CLI
ANGULAR_CLI_ANALYTICS=false

# API Configuration (if needed)
# API_URL=http://localhost:3000
# API_TIMEOUT=30000

# Feature Flags
# ENABLE_MOCK_API=true
# ENABLE_LOGGING=true

# Development Tools
# DEBUG=angular:*
